# Crucible — local config. Copy to .env and fill in.
# All keys are optional — the app degrades gracefully (demo data) if a key is missing.

# Server
PORT=4317
SESSION_SECRET=replace-me-with-a-long-random-string

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
# Set Authorization callback URL to: http://localhost:4317/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Claude Agent SDK — auth via your Claude Pro/Max/Team subscription, NO metered API tokens.
# Setup:
#   1. Install Claude Code: https://docs.claude.com/en/docs/claude-code/setup
#   2. Run:  claude setup-token
#   3. Copy the printed sk-ant-oat01-... token into the variable below.
# The token is good for ~1 year. Used by the Forging stage (eval extraction) and
# the Claude Opus judge in Tempering.
CLAUDE_CODE_OAUTH_TOKEN=

# Alternative: an Anthropic API key works too (will be billed against your account).
# If both are set, CLAUDE_CODE_OAUTH_TOKEN wins by SDK precedence.
ANTHROPIC_API_KEY=

# OpenRouter — used to run challenger models cheaply (one key, many providers)
OPENROUTER_API_KEY=

# ADAL CLI — when set, used as the coding agent during Probing/Forging.
# Falls back to Claude Agent SDK then to pattern matching if unset or not installed.
# Install: npm i -g @sylphai/adal-cli && adal   (log in once interactively)
ADAL_CMD=adal

# Model selection
JUDGE_MODEL=claude-opus-4-7
CHALLENGER_MODELS=anthropic/claude-haiku-4-5,openai/gpt-4o-mini,google/gemini-2.0-flash-001,meta-llama/llama-3.1-8b-instruct,mistralai/mistral-small
