# Crucible — local config. Copy to .env and fill in.
# All keys are optional — the app degrades gracefully (demo data) if a key is missing.

# Server
PORT=4317
SESSION_SECRET=replace-me-with-a-long-random-string

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
# Set Authorization callback URL to: http://localhost:4317/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- LEGACY (no longer read — kept for reference) -----------------------
# These powered the original Claude-SDK + OpenRouter path. The ADAL CLI now
# handles all LLM hops; auth is via `adal` itself (log in once interactively).
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- ADAL CLI ------------------------------------------------------------
# All LLM hops (forging, current model, challengers, judge) shell out to
# `adal`. Install: `npm i -g @sylphai/adal-cli` then run `adal` once
# interactively to cache credentials.
ADAL_CMD=adal
# Max concurrent `adal -q` subprocess calls. ADAL serializes on a per-user
# settings lock — start at 1 (safe), bump cautiously after testing.
ADAL_CONCURRENCY=1

# --- Models (ADAL catalog keys — see ~/.adal/model_catalog.json) --------
# Judge runs every comparison; Forger reads the cloned repo to draft evals.
JUDGE_MODEL=anthropic-claude-opus-4-7
FORGER_MODEL=anthropic-claude-sonnet-4-6
# Cheapest member of each major family. All must be valid catalog keys.
CHALLENGER_MODELS=zai-glm-4.7-flashx,anthropic-claude-haiku-4-5-20251001,google-gemini-3-flash-preview,openai-gpt-5-mini
